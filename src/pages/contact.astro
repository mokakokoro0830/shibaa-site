---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="お問い合わせ"
  description="しば海日和へのお問い合わせページ。記事への感想・コラボのご提案・ご質問などお気軽にどうぞ。"
>
  <div class="max-w-xl mx-auto px-4 py-12">
    <h1 class="text-2xl md:text-3xl font-bold mb-4">お問い合わせ</h1>
    <p class="text-gray-500 dark:text-gray-400 mb-8">
      記事への感想・コラボのご提案・ご質問などお気軽にどうぞ。
    </p>

    <form
      name="contact"
      method="POST"
      data-netlify="true"
      class="space-y-6"
    >
      <input type="hidden" name="form-name" value="contact" />

      <div>
        <label class="block text-sm font-medium mb-1" for="name">お名前</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-2.5 bg-white dark:bg-gray-800 text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-sky-400"
        />
      </div>

      <div>
        <label class="block text-sm font-medium mb-1" for="email">メールアドレス</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-2.5 bg-white dark:bg-gray-800 text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-sky-400"
        />
      </div>

      <div>
        <label class="block text-sm font-medium mb-1" for="message">メッセージ</label>
        <textarea
          id="message"
          name="message"
          rows="6"
          required
          class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-2.5 bg-white dark:bg-gray-800 text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-sky-400 resize-vertical"
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full bg-sky-600 hover:bg-sky-700 text-white font-medium py-3 rounded-lg transition-colors"
      >
        送信する
      </button>
    </form>
  </div>
</BaseLayout>

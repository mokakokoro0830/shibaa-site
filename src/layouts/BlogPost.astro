---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/blog/TableOfContents.astro';
import type { CollectionEntry } from 'astro:content';
import { getSlug } from '../utils/slug';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  post: CollectionEntry<'blog'>;
  headings?: Heading[];
}

const { post, headings = [] } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, category, author } = post.data;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  image: heroImage ? `https://shibaa.com${heroImage}` : 'https://shibaa.com/images/og-default.png',
  datePublished: pubDate.toISOString(),
  dateModified: updatedDate ? updatedDate.toISOString() : pubDate.toISOString(),
  author: {
    '@type': 'Person',
    name: author,
    url: 'https://shibaa.com/about',
  },
  publisher: {
    '@type': 'Organization',
    name: 'しば海日和',
    url: 'https://shibaa.com',
  },
};
---

<BaseLayout
  title={title}
  description={description}
  image={heroImage}
  type="article"
  pubDate={pubDate}
  updatedDate={updatedDate}
  jsonLd={jsonLd}
>
  <article class="max-w-4xl mx-auto px-4 py-8">
    {heroImage && (
      <img
        src={heroImage}
        alt={title}
        class="w-full h-64 md:h-96 object-cover rounded-xl shadow-lg mb-8"
      />
    )}

    <div class="flex flex-wrap items-center gap-3 mb-4 text-sm text-gray-500 dark:text-gray-400">
      <a
        href={`/category/${encodeURIComponent(category)}`}
        class="bg-sky-100 dark:bg-sky-900/30 text-sky-700 dark:text-sky-300 px-3 py-1 rounded-full no-underline hover:bg-sky-200 dark:hover:bg-sky-900/50 transition-colors"
      >
        {category}
      </a>
      <time datetime={pubDate.toISOString()}>
        {pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      {updatedDate && (
        <span>（更新: {updatedDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}）</span>
      )}
    </div>

    <h1 class="text-2xl md:text-3xl font-bold mb-6 leading-tight">{title}</h1>

    <div class="flex items-center gap-2 mb-8 pb-8 border-b border-gray-200 dark:border-gray-700">
      <div class="w-10 h-10 rounded-full bg-sky-100 dark:bg-sky-900 flex items-center justify-center text-xl">🐕</div>
      <span class="text-sm text-gray-600 dark:text-gray-400">{author}</span>
    </div>

    <div class="lg:flex lg:gap-8">
      {headings.length > 0 && (
        <aside class="hidden lg:block lg:w-64 lg:shrink-0">
          <div class="sticky top-20">
            <TableOfContents headings={headings} />
          </div>
        </aside>
      )}

      <div class="prose dark:prose-invert flex-1 min-w-0">
        {headings.length > 0 && (
          <div class="lg:hidden mb-8">
            <TableOfContents headings={headings} />
          </div>
        )}
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>

---
interface Props {
  title: string;
  image: string;
  price?: string;
  url: string;
  badge?: string;
}

const { title, image, price, url, badge } = Astro.props;
---

<div class="relative border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden hover:shadow-md transition-shadow bg-white dark:bg-gray-800">
  {badge && (
    <div class="absolute top-2 left-2 bg-sky-600 text-white text-xs font-bold px-2 py-0.5 rounded z-10">
      {badge}
    </div>
  )}
  <a
    href={url}
    target="_blank"
    rel="nofollow sponsored noopener noreferrer"
    class="block no-underline"
  >
    <img
      src={image}
      alt={title}
      class="w-full h-40 object-contain p-3"
      loading="lazy"
    />
    <div class="px-3 pb-3">
      <p class="text-sm font-medium text-gray-800 dark:text-gray-100 line-clamp-2 mb-1">{title}</p>
      {price && <p class="text-base font-bold text-orange-500">{price}</p>}
      <span class="inline-block mt-2 text-xs text-sky-600 dark:text-sky-400 font-medium">
        Amazonで見る →
      </span>
    </div>
  </a>
</div>

---
import type { CollectionEntry } from 'astro:content';
import { getSlug } from '../../utils/slug';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, heroImage, category } = post.data;
const slug = getSlug(post.id);
---

<article class="group bg-white dark:bg-gray-800 rounded-xl shadow-sm hover:shadow-md transition-shadow overflow-hidden border border-gray-100 dark:border-gray-700">
  <a href={`/blog/${slug}`} class="block no-underline">
    {heroImage ? (
      <img
        src={heroImage}
        alt={title}
        class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300"
      />
    ) : (
      <div class="w-full h-48 bg-gradient-to-br from-sky-100 to-sky-200 dark:from-sky-900 dark:to-sky-800 flex items-center justify-center text-5xl">
        🐕
      </div>
    )}

    <div class="p-4">
      <span class="inline-block text-xs font-medium text-sky-600 dark:text-sky-400 bg-sky-50 dark:bg-sky-900/30 px-2 py-0.5 rounded-full mb-2">
        {category}
      </span>
      <h3 class="text-base font-bold text-gray-800 dark:text-gray-100 mb-2 line-clamp-2 group-hover:text-sky-600 dark:group-hover:text-sky-400 transition-colors">
        {title}
      </h3>
      <p class="text-sm text-gray-500 dark:text-gray-400 line-clamp-2 mb-3">{description}</p>
      <time datetime={pubDate.toISOString()} class="text-xs text-gray-400 dark:text-gray-500">
        {pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </div>
  </a>
</article>
